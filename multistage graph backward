#include <stdio.h>
#define INF 9999

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int cost[n][n], dist[n];

    printf("Enter cost matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
            if(cost[i][j] == 0)
                cost[i][j] = INF;
        }
    }

    
    dist[n-1] = 0;

    for(int i = 0; i < n-1; i++)
        dist[i] = INF;

    
    for(int i = n-2; i >= 0; i--) {
        for(int j = i+1; j < n; j++) {
            if(cost[i][j] != INF && dist[i] > cost[i][j] + dist[j]) {
                dist[i] = cost[i][j] + dist[j];
            }
        }
    }

    printf("Minimum cost from 0 to %d = %d\n", n-1, dist[0]);

    return 0;
}
