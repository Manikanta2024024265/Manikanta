#include <stdio.h>
#define INF 999

int main() {
    int n, i, j, min, cost = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int a[n][n], visited[n];

    
    printf("Enter cost matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &a[i][j]);
            if(a[i][j] == 0)
                a[i][j] = INF;
        }
        visited[i] = 0;
    }

    visited[0] = 1; // start from 0

    printf("Edges:\n");

    for(int k = 0; k < n-1; k++) {
        min = INF;

        for(i = 0; i < n; i++) {
            if(visited[i]) {
                for(j = 0; j < n; j++) {
                    if(!visited[j] && a[i][j] < min) {
                        min = a[i][j];
                        int u = i, v = j;
                    }
                }
            }
        }

        printf("%d - %d = %d\n", u, v, min);

        cost += min;
        visited[v] = 1;
    }

    printf("Total cost = %d", cost);

    return 0;
}
