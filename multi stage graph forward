#include <stdio.h>
#define INF 9999

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int cost[n][n], dist[n];

    printf("Enter cost matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
            if(cost[i][j] == 0)
                cost[i][j] = INF;
        }
    }

    
    dist[0] = 0;

    for(int i = 1; i < n; i++)
        dist[i] = INF;

    
    for(int i = 0; i < n; i++) {
        for(int j = i+1; j < n; j++) {
            if(cost[i][j] != INF && dist[j] > dist[i] + cost[i][j]) {
                dist[j] = dist[i] + cost[i][j];
            }
        }
    }

    printf("Minimum cost from 0 to %d = %d\n", n-1, dist[n-1]);

    return 0;
}
